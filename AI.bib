	file = {Submitted Version:C\:\\Users\\yanglu\\Zotero\\storage\\DFF8G7Z5\\Hémous and Olsen - 2022 - The Rise of the Machines Automation, Horizontal Innovation, and Income Inequality.pdf:application/pdf},
